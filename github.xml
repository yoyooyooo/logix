        default: ""
      perf_steps_auto_max_total_collects:
        description: "auto 模式总 collect 上限（避免单次 run 过长）"
        required: false
        default: ""
      perf_steps_auto_time_budget_minutes:
        description: "auto 模式时间预算（分钟；超出则提前收敛）"
        required: false
        default: ""
      perf_steps_auto_collect_target:
        description: "auto 模式采集对象（base/head/both）"
        required: false
        default: ""
      perf_capacity_floor_min:
        description: "可选动态容量 floor 目标（整数；用于反向约束旧的 2000 门槛）"
        required: false
        default: "2000"
      perf_capacity_dynamic_history_window:
        description: "动态容量模型的历史窗口（最近 N 次）"
        required: false
        default: "5"
      perf_capacity_dynamic_min_history_runs:
        description: "启用 stableP50 前所需最小历史 run 数"
        required: false
        default: "3"
      perf_capacity_dynamic_hard_ratio:
        description: "dynamic hard floor 比例（hard=max(2000, stableP50*ratio)）"
        required: false
        default: "0.8"
      perf_capacity_dynamic_warn_ratio:
        description: "dynamic warn floor 比例（warn=stableP50*ratio）"
        required: false
        default: "0.9"
      perf_capacity_dynamic_enforce_hard:
        description: "是否启用 dynamic hard floor 失败门禁（true/false）"
        required: false
        default: ""
      perf_capacity_auto_retry_on_timeout:
        description: "head 采集出现 timeout 时是否自动重试一次（true/false）"
        required: false
        default: ""
      diff_mode:
        description: "diff 模式（strict=不可比直接失败；triage=允许漂移，仅作线索）"
        required: false
        default: ""
  schedule:
    # Nightly (UTC): heavier converge sweep for tracking default parameters over time.
    - cron: "0 19 * * *"
    # Weekly (UTC): broader coverage across perf-boundaries.
    - cron: "0 19 * * 0"

permissions:
  actions: read
  contents: read
  issues: write
  pull-requests: write

concurrency:
  # Avoid canceling long-running scheduled sweeps; keep manual/PR-triggered reruns cancelable.
  group: logix-perf-sweep-${{ github.event_name == 'schedule' && (github.event.schedule == '0 19 * * 0' && 'weekly' || 'nightly') || github.ref }}
  cancel-in-progress: ${{ github.event_name != 'schedule' }}

