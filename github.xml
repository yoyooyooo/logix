<file path="workflows/logix-perf-convergence-soak.yml">
name: logix-perf (convergence soak)

on:
  workflow_dispatch:
    inputs:
      base_ref:
        description: "before 基线（branch/tag/sha；留空=默认分支 tip）"
        required: false
        default: ""
      head_ref:
        description: "after 基线（branch/tag/sha；留空=触发 SHA）"
        required: false
        default: ""
      perf_files:
        description: "采集范围（相对 packages/logix-react；逗号分隔）"
        required: false
