<file path="workflows/logix-perf-convergence.yml">
name: logix-perf (convergence)

on:
  pull_request:
    paths:
      - ".github/scripts/logix-perf-*.cjs"
      - ".github/workflows/logix-perf-*.yml"
      - "examples/logix-react/**"
      - "packages/logix-core/**"
      - "packages/logix-perf-evidence/**"
      - "packages/logix-react/**"
      - "scripts/perf.ts"
  push:
    paths:
      - ".github/scripts/logix-perf-*.cjs"
      - ".github/workflows/logix-perf-*.yml"
      - "examples/logix-react/**"
      - "packages/logix-core/**"
      - "packages/logix-perf-evidence/**"
      - "packages/logix-react/**"
      - "scripts/perf.ts"
  workflow_dispatch:
    inputs:
      base_ref:
        description: "before 基线（branch/tag/sha；留空=默认分支 tip）"
        required: false
        default: ""
      head_ref:
        description: "after 基线（branch/tag/sha；留空=触发 SHA）"
        required: false
        default: ""
      perf_profile:
        description: "采样 profile（default/soak；quick 只作诊断线索）"
        required: false
        default: "default"
      perf_files:
        description: "采集范围（相对 packages/logix-react；逗号分隔）"
        required: false
        default: "test/browser/perf-boundaries"
      run_browser_p2:
        description: "是否运行 examples/playground P2 浏览器采集"
        required: false
        default: "true"
      fail_on_blocked:
        description: "final gate blocked/incomplete 时是否让 workflow 失败"
        required: false
        default: "true"
  workflow_call:
    inputs:
      base_ref:
        description: "before 基线（branch/tag/sha；留空=默认分支 tip）"
        required: false
        type: string
        default: ""
      head_ref:
        description: "after 基线（branch/tag/sha；留空=触发 SHA）"
        required: false
        type: string
        default: ""
      perf_profile:
        description: "采样 profile（default/soak；quick 只作诊断线索）"
        required: false
        type: string
        default: "default"
      perf_files:
        description: "采集范围（相对 packages/logix-react；逗号分隔）"
        required: false
        type: string
        default: "test/browser/perf-boundaries"
      run_browser_p2:
        description: "是否运行 examples/playground P2 浏览器采集"
        required: false
        type: string
        default: "false"
      fail_on_blocked:
        description: "final gate blocked/incomplete 时是否让 workflow 失败"
        required: false
        type: string
        default: "false"
  schedule:
    - cron: "0 20 * * *"

permissions:
  contents: read

concurrency:
  group: logix-perf-convergence-${{ github.event_name == 'schedule' && 'nightly' || github.ref }}
  cancel-in-progress: ${{ github.event_name != 'schedule' && github.event_name != 'workflow_call' }}

jobs:
  convergence:
    runs-on: ubuntu-latest
    timeout-minutes: 240
    env:
      PERF_PROFILE: default
      PERF_FILES: test/browser/perf-boundaries
      PERF_OUT_DIR: perf/convergence
      PERF_ARTIFACT_NAME: logix-perf-convergence-${{ github.run_id }}
      RUN_BROWSER_P2: "false"
      FAIL_ON_BLOCKED: "false"

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Compute SHAs and inputs
        env:
          INPUT_BASE_REF: ${{ inputs.base_ref || github.event.inputs.base_ref }}
          INPUT_HEAD_REF: ${{ inputs.head_ref || github.event.inputs.head_ref }}
          INPUT_PERF_PROFILE: ${{ inputs.perf_profile || github.event.inputs.perf_profile }}
          INPUT_PERF_FILES: ${{ inputs.perf_files || github.event.inputs.perf_files }}
          INPUT_RUN_BROWSER_P2: ${{ inputs.run_browser_p2 || github.event.inputs.run_browser_p2 }}
          INPUT_FAIL_ON_BLOCKED: ${{ inputs.fail_on_blocked || github.event.inputs.fail_on_blocked }}
        run: |
          set -euo pipefail

          echo "PERF_ENV_ID=gh-${RUNNER_OS}-${RUNNER_ARCH}" >> "$GITHUB_ENV"

          normalize_ref() {
            local ref="$1"
            ref="${ref#refs/heads/}"
            ref="${ref#refs/remotes/origin/}"
            ref="${ref#origin/}"
            echo "$ref"
          }

          resolve_ref_to_sha() {
            local ref="$1"
            if git rev-parse --verify "${ref}^{commit}" >/dev/null 2>&1; then
              git rev-parse "${ref}^{commit}"
              return 0
            fi
            git fetch origin "$ref" --depth=1
            git rev-parse FETCH_HEAD
          }

          DEFAULT_BRANCH="${{ github.event.repository.default_branch }}"
          BASE_REF="$(normalize_ref "${INPUT_BASE_REF:-}")"
          HEAD_REF="$(normalize_ref "${INPUT_HEAD_REF:-}")"

          if [ -z "$BASE_REF" ]; then
            if [ "${{ github.event_name }}" = "pull_request" ]; then
              BASE_REF="${{ github.event.pull_request.base.sha }}"
              HEAD_REF="${{ github.event.pull_request.head.sha }}"
            elif [ "${{ github.event_name }}" = "push" ]; then
              HEAD_REF="$GITHUB_SHA"
              BASE_REF="${{ github.event.before }}"
              if [ -z "$BASE_REF" ] || [ "$BASE_REF" = "0000000000000000000000000000000000000000" ]; then
                BASE_REF="$DEFAULT_BRANCH"
              fi
            elif [ "${{ github.event_name }}" = "schedule" ]; then
              HEAD_REF="$GITHUB_SHA"
              BASE_REF="$(git rev-parse "${GITHUB_SHA}^" 2>/dev/null || echo "$GITHUB_SHA")"
              echo "RUN_BROWSER_P2=true" >> "$GITHUB_ENV"
            else
              BASE_REF="$DEFAULT_BRANCH"
            fi
          fi
          if [ -z "$HEAD_REF" ]; then
            HEAD_REF="$GITHUB_SHA"
          fi

          BASE_SHA="$(resolve_ref_to_sha "$BASE_REF")"
          HEAD_SHA="$(resolve_ref_to_sha "$HEAD_REF")"

          echo "BASE_REF=$BASE_REF" >> "$GITHUB_ENV"
          echo "HEAD_REF=$HEAD_REF" >> "$GITHUB_ENV"
          echo "BASE_SHA=$BASE_SHA" >> "$GITHUB_ENV"
          echo "HEAD_SHA=$HEAD_SHA" >> "$GITHUB_ENV"
          echo "BASE_SHORT=${BASE_SHA::8}" >> "$GITHUB_ENV"
          echo "HEAD_SHORT=${HEAD_SHA::8}" >> "$GITHUB_ENV"

          if [ -n "${INPUT_PERF_PROFILE:-}" ]; then
            echo "PERF_PROFILE=$INPUT_PERF_PROFILE" >> "$GITHUB_ENV"
          fi
          if [ -n "${INPUT_PERF_FILES:-}" ]; then
            echo "PERF_FILES=$INPUT_PERF_FILES" >> "$GITHUB_ENV"
          fi
          if [ -n "${INPUT_RUN_BROWSER_P2:-}" ]; then
            echo "RUN_BROWSER_P2=$INPUT_RUN_BROWSER_P2" >> "$GITHUB_ENV"
          fi
          if [ -n "${INPUT_FAIL_ON_BLOCKED:-}" ]; then
            echo "FAIL_ON_BLOCKED=$INPUT_FAIL_ON_BLOCKED" >> "$GITHUB_ENV"
          fi

          if git diff --name-only "$BASE_SHA" "$HEAD_SHA" -- pnpm-lock.yaml | grep -q '^pnpm-lock.yaml$'; then
            echo "LOCKFILE_CHANGED=1" >> "$GITHUB_ENV"
          else
            echo "LOCKFILE_CHANGED=0" >> "$GITHUB_ENV"
          fi

      - name: Checkout head (for install)
        run: git checkout --quiet -f "$HEAD_SHA"

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 9.15.9

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm

      - name: Cache Playwright browsers
        uses: actions/cache@v4
        with:
          path: ~/.cache/ms-playwright
          key: ${{ runner.os }}-playwright-${{ hashFiles('pnpm-lock.yaml') }}

      - name: Install dependencies
        run: |
          pnpm install --frozen-lockfile
          if [ ! -e node_modules/@logixjs/perf-evidence ]; then
            mkdir -p node_modules/@logixjs
            ln -s "$PWD/packages/logix-perf-evidence" node_modules/@logixjs/perf-evidence
          fi
          if [ -d packages/logix-react/node_modules ] && [ ! -e packages/logix-react/node_modules/@logixjs/perf-evidence ]; then
            mkdir -p packages/logix-react/node_modules/@logixjs
            ln -s "$PWD/packages/logix-perf-evidence" packages/logix-react/node_modules/@logixjs/perf-evidence
          fi

      - name: Perf preflight
        run: pnpm -C packages/logix-perf-evidence run ci:preflight

      - name: Install Playwright Chromium deps
        run: pnpm exec playwright install --with-deps chromium

      - name: Pin perf matrix and Vitest shared config
        run: |
          set -euo pipefail
          PINNED_MATRIX="$RUNNER_TEMP/logix-perf-matrix.json"
          PINNED_VITEST_SHARED="$RUNNER_TEMP/vitest.shared.ts"
          cp packages/logix-perf-evidence/assets/matrix.json "$PINNED_MATRIX"
          cp vitest.shared.ts "$PINNED_VITEST_SHARED"
          echo "PERF_PINNED_MATRIX=$PINNED_MATRIX" >> "$GITHUB_ENV"
          echo "PERF_PINNED_VITEST_SHARED=$PINNED_VITEST_SHARED" >> "$GITHUB_ENV"

      - name: Collect base
        run: |
          set -euo pipefail
          mkdir -p "$PERF_OUT_DIR"
          git update-index --no-assume-unchanged packages/logix-perf-evidence/assets/matrix.json || true
          git checkout --quiet -f "$BASE_SHA"
          if [ "${LOCKFILE_CHANGED:-0}" = "1" ]; then
            pnpm install --frozen-lockfile
          fi
          cp "$PERF_PINNED_VITEST_SHARED" vitest.shared.ts
          mkdir -p packages/logix-perf-evidence/assets
          git update-index --assume-unchanged packages/logix-perf-evidence/assets/matrix.json || true
          cp "$PERF_PINNED_MATRIX" packages/logix-perf-evidence/assets/matrix.json
          if [ ! -e node_modules/@logixjs/perf-evidence ]; then
            mkdir -p node_modules/@logixjs
            ln -s "$PWD/packages/logix-perf-evidence" node_modules/@logixjs/perf-evidence
          fi
          if [ -d packages/logix-react/node_modules ] && [ ! -e packages/logix-react/node_modules/@logixjs/perf-evidence ]; then
            mkdir -p packages/logix-react/node_modules/@logixjs
            ln -s "$PWD/packages/logix-perf-evidence" packages/logix-react/node_modules/@logixjs/perf-evidence
          fi
          IFS=',' read -r -a PERF_FILES_ARRAY <<< "${PERF_FILES}"
          FILE_ARGS=()
          for f in "${PERF_FILES_ARRAY[@]}"; do
            f="$(echo "$f" | xargs)"
            if [ -n "$f" ]; then
              FILE_ARGS+=(--files "$f")
            fi
          done
          VITE_LOGIX_PERF_HARD_GATES=off pnpm perf collect -- --profile "$PERF_PROFILE" \
            "${FILE_ARGS[@]}" \
            --out "$PERF_OUT_DIR/before.${BASE_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json"
          git update-index --no-assume-unchanged packages/logix-perf-evidence/assets/matrix.json || true

      - name: Collect head
        run: |
          set -euo pipefail
          git update-index --no-assume-unchanged packages/logix-perf-evidence/assets/matrix.json || true
          git checkout --quiet -f "$HEAD_SHA"
          if [ "${LOCKFILE_CHANGED:-0}" = "1" ]; then
            pnpm install --frozen-lockfile
          fi
          cp "$PERF_PINNED_VITEST_SHARED" vitest.shared.ts
          mkdir -p packages/logix-perf-evidence/assets
          git update-index --assume-unchanged packages/logix-perf-evidence/assets/matrix.json || true
          cp "$PERF_PINNED_MATRIX" packages/logix-perf-evidence/assets/matrix.json
          if [ ! -e node_modules/@logixjs/perf-evidence ]; then
            mkdir -p node_modules/@logixjs
            ln -s "$PWD/packages/logix-perf-evidence" node_modules/@logixjs/perf-evidence
          fi
          if [ -d packages/logix-react/node_modules ] && [ ! -e packages/logix-react/node_modules/@logixjs/perf-evidence ]; then
            mkdir -p packages/logix-react/node_modules/@logixjs
            ln -s "$PWD/packages/logix-perf-evidence" packages/logix-react/node_modules/@logixjs/perf-evidence
          fi
          IFS=',' read -r -a PERF_FILES_ARRAY <<< "${PERF_FILES}"
          FILE_ARGS=()
          for f in "${PERF_FILES_ARRAY[@]}"; do
            f="$(echo "$f" | xargs)"
            if [ -n "$f" ]; then
              FILE_ARGS+=(--files "$f")
            fi
          done
          VITE_LOGIX_PERF_HARD_GATES=off pnpm perf collect -- --profile "$PERF_PROFILE" \
            "${FILE_ARGS[@]}" \
            --out "$PERF_OUT_DIR/after.${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json"
          git update-index --no-assume-unchanged packages/logix-perf-evidence/assets/matrix.json || true

      - name: Normalize reports
        run: |
          node .github/scripts/logix-perf-normalize-ci-reports.cjs \
            --before "$PERF_OUT_DIR/before.${BASE_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --after "$PERF_OUT_DIR/after.${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --matrix "$PERF_PINNED_MATRIX"

      - name: Diff base..head
        run: |
          pnpm perf diff -- \
            --before "$PERF_OUT_DIR/before.${BASE_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --after "$PERF_OUT_DIR/after.${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --out "$PERF_OUT_DIR/diff.${BASE_SHORT}__${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json"

      - name: Adversarial matrix report
        if: always()
        continue-on-error: true
        run: |
          pnpm exec tsx packages/logix-perf-evidence/scripts/ci.adversarial-matrix-report.ts \
            --diff "$PERF_OUT_DIR/diff.${BASE_SHORT}__${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --before "$PERF_OUT_DIR/before.${BASE_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --after "$PERF_OUT_DIR/after.${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --profile "adversarial-${PERF_PROFILE}" \
            --out "$PERF_OUT_DIR/adversarial.${PERF_PROFILE}.md" \
            --json-out "$PERF_OUT_DIR/adversarial.${PERF_PROFILE}.json"

      - name: Browser P2 evidence
        if: always() && env.RUN_BROWSER_P2 == 'true'
        continue-on-error: true
        run: |
          set +e
          mkdir -p "$PERF_OUT_DIR/logs"
          pnpm -C examples/logix-react test:browser:playground > "$PERF_OUT_DIR/logs/test-browser-playground.${PERF_PROFILE}.log" 2>&1
          PLAYGROUND_STATUS=$?
          pnpm -C examples/logix-react test:browser:live-real-carrier > "$PERF_OUT_DIR/logs/test-browser-live-real-carrier.${PERF_PROFILE}.log" 2>&1
          LIVE_STATUS=$?
          export PLAYGROUND_STATUS LIVE_STATUS
          node - <<'NODE'
          const fs = require('node:fs')
          const outDir = process.env.PERF_OUT_DIR
          const profile = process.env.PERF_PROFILE
          const playgroundStatus = Number(process.env.PLAYGROUND_STATUS || '0')
          const liveStatus = Number(process.env.LIVE_STATUS || '0')
          const input = {
            schemaVersion: 1,
            generatedAt: new Date().toISOString(),
            profile,
            runtime: {
              status: liveStatus === 0 ? 'pass' : 'fail',
              kernelOnly: liveStatus === 0,
              publicResidueViolation: liveStatus === 0 ? 0 : 1,
              evidenceRef: `${outDir}/logs/test-browser-live-real-carrier.${profile}.log`,
            },
            playground: {
              status: playgroundStatus === 0 ? 'pass' : 'fail',
              productCostSeparated: playgroundStatus === 0,
              kernelPlaygroundCostMixed: playgroundStatus === 0 ? 0 : 1,
              evidenceRef: `${outDir}/logs/test-browser-playground.${profile}.log`,
            },
          }
          fs.writeFileSync(`${outDir}/examples-playground.${profile}.input.json`, `${JSON.stringify(input, null, 2)}\n`)
          NODE
          pnpm exec tsx packages/logix-perf-evidence/scripts/ci.examples-playground-isolation-report.ts \
            --input "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.input.json" \
            --profile "$PERF_PROFILE" \
            --out "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.md" \
            --json-out "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.json"
      - name: Browser P2 skipped marker
        if: always() && env.RUN_BROWSER_P2 != 'true'
        run: |
          mkdir -p "$PERF_OUT_DIR"
          cat > "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.input.json" <<EOF
          {
            "schemaVersion": 1,
            "generatedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
            "profile": "${PERF_PROFILE}",
            "runtime": { "status": "missing" },
            "playground": { "status": "missing" }
          }
          EOF
          pnpm exec tsx packages/logix-perf-evidence/scripts/ci.examples-playground-isolation-report.ts \
            --input "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.input.json" \
            --profile "$PERF_PROFILE" \
            --out "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.md" \
            --json-out "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.json" || true

      - name: Assemble final convergence evidence
        if: always()
        continue-on-error: true
        run: |
          pnpm perf ci:kernel-performance-convergence-assembly-input -- \
            --before "$PERF_OUT_DIR/before.${BASE_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --after "$PERF_OUT_DIR/after.${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --diff "$PERF_OUT_DIR/diff.${BASE_SHORT}__${HEAD_SHORT}.${PERF_ENV_ID}.${PERF_PROFILE}.json" \
            --adversarial-report "$PERF_OUT_DIR/adversarial.${PERF_PROFILE}.json" \
            --examples-report "$PERF_OUT_DIR/examples-playground.${PERF_PROFILE}.json" \
            --profile "adversarial-${PERF_PROFILE}" \
            --out "$PERF_OUT_DIR/assembly.${PERF_PROFILE}.json"
          pnpm exec tsx packages/logix-perf-evidence/scripts/assemble-kernel-performance-convergence-manifest.ts \
            --input "$PERF_OUT_DIR/assembly.${PERF_PROFILE}.json" \
            --out "$PERF_OUT_DIR/convergence.${PERF_PROFILE}.manifest.json"
          pnpm exec tsx packages/logix-perf-evidence/scripts/ci.kernel-performance-convergence-stage-gate.ts \
            --manifest "$PERF_OUT_DIR/convergence.${PERF_PROFILE}.manifest.json" \
            --profile "adversarial-${PERF_PROFILE}" \
            --out "$PERF_OUT_DIR/convergence.${PERF_PROFILE}.md" \
            --json-out "$PERF_OUT_DIR/convergence.${PERF_PROFILE}.json" || true

      - name: Write summary
        if: always()
        run: node .github/scripts/logix-perf-convergence-summary.cjs

      - name: Upload artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: ${{ env.PERF_ARTIFACT_NAME }}
          path: ${{ env.PERF_OUT_DIR }}
          if-no-files-found: warn

      - name: Enforce final gate
        if: always() && env.FAIL_ON_BLOCKED == 'true'
        run: |
          node - <<'NODE'
          const fs = require('node:fs')
          const reportPath = `${process.env.PERF_OUT_DIR}/convergence.${process.env.PERF_PROFILE}.json`
          const report = JSON.parse(fs.readFileSync(reportPath, 'utf8'))
          if (report.classification !== 'complete') {
            console.error(`final gate did not complete: classification=${report.classification} claimStrength=${report.claimStrength}`)
            process.exit(1)
          }
          NODE
</file>

