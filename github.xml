<file path="workflows/codex-review.yml">
name: codex-review

on:
  pull_request:
    types:
      - opened
      - synchronize
      - reopened
      - ready_for_review

permissions:
  contents: read
  pull-requests: write
  issues: write

concurrency:
  group: codex-review-${{ github.event.pull_request.number || github.ref }}
  cancel-in-progress: true

jobs:
  review:
    if: ${{ github.event.pull_request.draft == false }}
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Build PR review prompt
        env:
          PR_NUMBER: ${{ github.event.pull_request.number }}
          PR_TITLE: ${{ github.event.pull_request.title }}
          BASE_SHA: ${{ github.event.pull_request.base.sha }}
          HEAD_SHA: ${{ github.event.pull_request.head.sha }}
        run: |
          set -euo pipefail

          PROMPT_FILE="$RUNNER_TEMP/codex-review-prompt.md"
          FILE_LIST="$RUNNER_TEMP/pr-files.txt"
          DIFF_FILE="$RUNNER_TEMP/pr.diff"

          git diff --name-only "$BASE_SHA...$HEAD_SHA" > "$FILE_LIST"
          git diff --stat "$BASE_SHA...$HEAD_SHA" > "$RUNNER_TEMP/pr.diff.stat"
          git diff --unified=3 "$BASE_SHA...$HEAD_SHA" > "$DIFF_FILE"

          FILE_COUNT="$(wc -l < "$FILE_LIST" | tr -d ' ')"
          DIFF_LINES="$(wc -l < "$DIFF_FILE" | tr -d ' ')"

          echo "PR_CHANGED_FILES=$FILE_COUNT" >> "$GITHUB_ENV"

          {
            echo "# PR Review Task"
            echo
            echo "- pr: #$PR_NUMBER"
            echo "- title: $PR_TITLE"
            echo "- base: $BASE_SHA"
            echo "- head: $HEAD_SHA"
            echo "- changed_files: $FILE_COUNT"
            echo
            echo "你是本仓库代码评审助手，请只基于 **base...head diff** 评审。"
            echo "关键约束："
            echo "- 你当前在 CI merge checkout，\`git status\` 为空是正常现象，禁止据此得出“无改动”。"
            echo "- 禁止输出与本次评审无关的流程文本（例如 AGENTS、project-guide、Speckit、spec-kit）。"
            echo "- 禁止使用工作区空 \`git diff\` 作为结论。"
            echo "你可以继续执行以下命令取证："
            echo "- \`git diff --name-status $BASE_SHA...$HEAD_SHA\`"
            echo "- \`git diff --unified=3 $BASE_SHA...$HEAD_SHA -- <path>\`"
            echo
            echo "输出要求（Markdown）："
            echo "1) 必须包含以下 3 个标题："
            echo "   - ## Critical Findings"
            echo "   - ## Non-critical Risks"
            echo "   - ## Coverage"
            echo "2) Critical Findings：按严重度排序给出高风险问题；若无，则只写一行：No critical issues found."
            echo "3) Non-critical Risks：即使无 critical，也至少给 1 条中低风险观察或可改进项（不能留空）。"
            echo "4) Coverage：列出你实际检查的文件路径；若未覆盖全部 changed files，明确写出未覆盖文件。"
            echo "5) 每条问题都要包含：问题 + 原因 + 建议修复 + 影响（性能/内存/并发事务语义/可诊断性）。"
            echo
            echo "## Changed files"
            if [ "$FILE_COUNT" -eq 0 ]; then
              echo "- (none)"
            else
              sed 's/^/- /' "$FILE_LIST"
            fi
            echo
            echo "## Diff stat"
            cat "$RUNNER_TEMP/pr.diff.stat"
            echo
            echo "## Diff excerpt"
            if [ "$DIFF_LINES" -eq 0 ]; then
              echo "(empty)"
            else
              sed -n '1,1600p' "$DIFF_FILE"
              if [ "$DIFF_LINES" -gt 1600 ]; then
                echo
                echo "[diff truncated: total_lines=$DIFF_LINES]"
              fi
            fi
          } > "$PROMPT_FILE"

          echo "CODEX_PROMPT_FILE=$PROMPT_FILE" >> "$GITHUB_ENV"

      - name: Run Codex review
        id: codex
        uses: openai/codex-action@v1
        with:
          openai-api-key: ${{ secrets.OPENAI_API_KEY }}
          responses-api-endpoint: ${{ secrets.OPENAI_BASE_URL }}
          prompt-file: ${{ env.CODEX_PROMPT_FILE }}
          effort: medium

      - name: Validate Codex review output
        id: validate
        env:
          CODEX_REVIEW: ${{ steps.codex.outputs.final-message }}
          PR_CHANGED_FILES: ${{ env.PR_CHANGED_FILES }}
        run: |
          set -euo pipefail

          REVIEW_FILE="$RUNNER_TEMP/codex-review-output.md"
          printf '%s\n' "${CODEX_REVIEW}" > "$REVIEW_FILE"

          reason=""

          if [ -z "$(tr -d '[:space:]' < "$REVIEW_FILE")" ]; then
            reason="empty_output"
          fi

          if [ -z "$reason" ] && grep -Eiq "couldn[’']t locate any PR diffs|there was nothing to review|Speckit noted|project guide|project-guide|AGENTS\\.md" "$REVIEW_FILE"; then
            reason="off_topic_or_bad_diff_basis"
          fi

          if [ -z "$reason" ]; then
            for section in "## Critical Findings" "## Non-critical Risks" "## Coverage"; do
              if ! grep -Fq "$section" "$REVIEW_FILE"; then
                reason="missing_required_sections"
                break
              fi
            done
          fi

          if [ -z "$reason" ] && grep -Eq "^No critical issues found\\.?$" "$REVIEW_FILE" && [ "${PR_CHANGED_FILES:-0}" -gt 0 ]; then
            WORD_COUNT="$(wc -w < "$REVIEW_FILE" | tr -d ' ')"
            if [ "$WORD_COUNT" -lt 40 ]; then
              reason="too_short_no_critical_for_nonempty_diff"
            fi
          fi

          if [ -n "$reason" ]; then
            echo "review-valid=false" >> "$GITHUB_OUTPUT"
            echo "reason=$reason" >> "$GITHUB_OUTPUT"
          else
            echo "review-valid=true" >> "$GITHUB_OUTPUT"
            echo "reason=ok" >> "$GITHUB_OUTPUT"
          fi

      - name: Fail on invalid Codex review output
        if: ${{ steps.validate.outputs.review-valid != 'true' }}
        env:
          REVIEW_INVALID_REASON: ${{ steps.validate.outputs.reason }}
        run: |
          echo "::error::Invalid Codex review output: $REVIEW_INVALID_REASON"
          exit 1

      - name: Upsert PR review comment
        if: ${{ steps.codex.outputs.final-message != '' && steps.validate.outputs.review-valid == 'true' }}
        uses: actions/github-script@v7
        env:
          CODEX_REVIEW: ${{ steps.codex.outputs.final-message }}
        with:
          script: |
            const marker = '<!-- codex-review -->'
            const body = `${marker}\n## Codex Review\n\n${process.env.CODEX_REVIEW}`
            const { owner, repo } = context.repo
            const issue_number = context.issue.number

            const { data: comments } = await github.rest.issues.listComments({
              owner,
              repo,
              issue_number,
              per_page: 100,
            })

            const existing = comments.find(
              (comment) => comment.user?.type === 'Bot' && comment.body?.includes(marker),
            )

            if (existing) {
              await github.rest.issues.updateComment({
                owner,
                repo,
                comment_id: existing.id,
                body,
              })
            } else {
              await github.rest.issues.createComment({
                owner,
                repo,
                issue_number,
                body,
              })
            }
