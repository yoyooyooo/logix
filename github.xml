md += `- status: ${code(conclusion)}\n`
if (debugTimelineLines.length > 0) {
  const tailSize = 24
  const tailLines = debugTimelineLines.slice(-tailSize)
  md += `- debug timeline: ${code(debugTimelinePath)} (tail=${code(tailLines.length)})\n`
