<file path="workflows/logix-perf-sweep.yml">
name: logix-perf (sweep)

on:
  workflow_dispatch:
    inputs:
      base_ref:
        description: "before 基线（branch/tag/sha；留空=默认分支 tip）"
        required: false
        default: ""
      head_ref:
        description: "after 基线（branch/tag/sha；留空=触发 SHA）"
        required: false
        default: ""
      run_preset:
        description: "运行预设（fast=快速疏通；curve=固定区间曲线；full=完整采集）"
        required: false
        default: "fast"
      perf_files:
        description: "采集范围（logix-react browser perf 测试文件/目录；支持逗号分隔多个，相对 packages/logix-react）"
        required: false
        default: "test/browser/perf-boundaries/converge-steps.test.tsx"
      perf_profile:
        description: "采样 profile（smoke/quick/default/soak；影响 runs/warmup/timeout）"
        required: false
        default: ""
      perf_steps_levels:
        description: "可选 steps 轴覆盖（CSV；例如 200,400,800,1200,1600,2000,2400,2800,3200）"
