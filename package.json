{
  "name": "intent-flow",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:pkg": "turbo run build --filter='./packages/*'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:beta": "node scripts/release-beta.mjs",
    "release:check": "changeset status --verbose",
    "ci:release:beta": "pnpm check:effect-v4-matrix && pnpm build:pkg && pnpm typecheck && pnpm typecheck:test && pnpm test:turbo",
    "typecheck": "pnpm -r typecheck",
    "typecheck:test": "pnpm -r typecheck:test",
    "verify": "pnpm verify:public-submodules",
    "check:forbidden-patterns": "tsx scripts/checks/forbidden-patterns.ts",
    "check:effect-v4-matrix": "tsx scripts/checks/effect-v4-matrix.ts",
    "verify:public-submodules": "tsx scripts/public-submodules/verify.ts",
    "lint": "pnpm lint:oxlint && pnpm lint:eslint",
    "lint:eslint": "eslint \"apps/**/src/**/*.{ts,tsx}\" \"packages/**/src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"apps/**/src/**/*.{ts,tsx}\" \"packages/**/src/**/*.{ts,tsx}\" --fix",
    "lint:oxlint": "oxlint -c .oxlintrc.json --deny-warnings apps packages",
    "format": "oxfmt apps packages examples",
    "format:all": "oxfmt .",
    "format:check": "oxfmt --check apps packages",
    "perf": "tsx scripts/perf.ts",
    "speckit:kanban": "pnpm -C packages/speckit-kit build && speckit-kit kanban",
    "speckit:kanban:dev": "tsx scripts/speckit-kanban.ts",
    "test": "vitest run --cache --silent=passed-only --reporter=dot --hideSkippedTests",
    "test:changed": "vitest run --cache --changed --silent=passed-only --reporter=dot --hideSkippedTests",
    "test:cache": "pnpm test",
    "test:fast": "bun x vitest run",
    "test:full": "vitest run",
    "test:browser": "pnpm -C packages/logix-react test -- --project browser && pnpm -C packages/logix-sandbox test:browser",
    "test:browser:release": "pnpm -C packages/logix-react exec vitest run test/browser/browser-environment-smoke.test.tsx --project browser",
    "test:watch": "vitest",
    "test:turbo": "turbo run test --ui=stream --output-logs=new-only --log-prefix=none --summarize=true --filter='./packages/*' --filter='./apps/logix-galaxy-api' --filter='./examples/effect-api' --filter='./examples/logix-react' -- --run --cache --project=!browser* --silent=passed-only --reporter=dot --hideSkippedTests",
    "coverage": "vitest run --coverage",
    "skills": "tsx scripts/skill-runner.ts",
    "api-reference:build": "pnpm -C apps/api-reference docgen",
    "api-reference:serve": "pnpm -C apps/api-reference serve",
    "api-reference:dev": "pnpm -C apps/api-reference docgen && pnpm -C apps/api-reference serve",
    "check:schema-v4-legacy": "tsx scripts/checks/schema-v4-legacy.ts"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.56.0",
    "@eslint/js": "^9.39.1",
    "@logixjs/core": "workspace:*",
    "@logixjs/core-ng": "workspace:*",
    "@types/prompts": "^2.4.9",
    "@vitest/browser": "^4.0.15",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "effect": "4.0.0-beta.28",
    "eslint": "^9.39.1",
    "eslint-plugin-oxlint": "^1.33.0",
    "fast-glob": "^3.3.2",
    "happy-dom": "^20.0.11",
    "jsdom": "24.0.0",
    "oxfmt": "^0.20.0",
    "oxlint": "^1.33.0",
    "playwright": "^1.57.0",
    "prompts": "^2.4.2",
    "speckit-kit": "workspace:*",
    "ts-morph": "^25.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.6.1",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.15",
    "vitest-browser-react": "^2.0.2"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "@effect/platform-node": "4.0.0-beta.28",
      "@effect/sql-pg": "4.0.0-beta.28",
      "@effect/vitest": "4.0.0-beta.28",
      "effect": "4.0.0-beta.28"
    }
  }
}
