{
  "name": "@logixjs/domain",
  "version": "1.0.2-beta.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoyooyooo/logix",
    "directory": "packages/domain"
  },
  "license": "Apache-2.0",
  "description": "Program-first domain pattern kits for the current Logix runtime",
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": null,
    "./Crud": "./src/Crud.ts",
    "./internal/*": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": null,
      "./Crud": {
        "types": "./dist/Crud.d.ts",
        "import": "./dist/Crud.js",
        "require": "./dist/Crud.cjs"
      },
      "./internal/*": null
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup --format cjs,esm --dts",
    "dev": "tsup --watch",
    "demo:crud": "tsx demos/crud.business.ts",
    "demo:crud:optimistic": "tsx demos/optimistic-crud/demo.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:cache": "vitest run --cache",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@logixjs/core": "workspace:*",
    "effect": "4.0.0-beta.28"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.28",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "@logixjs/core": "workspace:*",
    "effect": "4.0.0-beta.28"
  }
}
