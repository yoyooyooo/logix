{
  "name": "@logixjs/core",
  "version": "1.0.2-beta.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoyooyooo/logix",
    "directory": "packages/logix-core"
  },
  "license": "Apache-2.0",
  "description": "The pure logic engine for Logix",
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./repo-internal/InternalContracts": "./src/internal/InternalContracts.ts",
    "./repo-internal/debug-api": "./src/internal/debug-api.ts",
    "./repo-internal/effect-op": "./src/internal/effect-op.ts",
    "./repo-internal/evidence-api": "./src/internal/evidence-api.ts",
    "./repo-internal/field-contracts": "./src/internal/field-contracts.ts",
    "./repo-internal/kernel-api": "./src/internal/kernel-api.ts",
    "./repo-internal/read-contracts": "./src/internal/read-contracts.ts",
    "./repo-internal/reflection-api": "./src/internal/reflection-api.ts",
    "./repo-internal/runtime-contracts": "./src/internal/runtime-contracts.ts",
    "./repo-internal/workbench-api": "./src/internal/workbench-api.ts",
    "./ControlPlane": "./src/ControlPlane.ts",
    "./Module": "./src/Module.ts",
    "./Program": "./src/Program.ts",
    "./Runtime": "./src/Runtime.ts",
    "./internal/*": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./repo-internal/InternalContracts": null,
      "./repo-internal/debug-api": null,
      "./repo-internal/effect-op": null,
      "./repo-internal/evidence-api": null,
      "./repo-internal/field-contracts": null,
      "./repo-internal/kernel-api": null,
      "./repo-internal/read-contracts": null,
      "./repo-internal/reflection-api": null,
      "./repo-internal/runtime-contracts": null,
      "./repo-internal/workbench-api": null,
      "./ControlPlane": {
        "types": "./dist/ControlPlane.d.ts",
        "import": "./dist/ControlPlane.js",
        "require": "./dist/ControlPlane.cjs"
      },
      "./Module": {
        "types": "./dist/Module.d.ts",
        "import": "./dist/Module.js",
        "require": "./dist/Module.cjs"
      },
      "./Program": {
        "types": "./dist/Program.d.ts",
        "import": "./dist/Program.js",
        "require": "./dist/Program.cjs"
      },
      "./Runtime": {
        "types": "./dist/Runtime.d.ts",
        "import": "./dist/Runtime.js",
        "require": "./dist/Runtime.cjs"
      },
      "./internal/*": null
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup --format cjs,esm --dts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:cache": "vitest run --cache",
    "test:watch": "vitest"
  },
  "dependencies": {
    "effect": "4.0.0-beta.28",
    "mutative": "^1.0.4"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.28",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.28"
  }
}
