{
  "budgetControllerCases": [
    {
      "id": "time_budget_reserve_denies_collect",
      "config": {
        "timeBudgetMinutes": 1,
        "reserveMinutes": 0.25,
        "maxTotalCollects": 10,
        "minCollectEstimateSeconds": 10
      },
      "timeline": [
        {
          "action": "canRunCollect",
          "atMs": 34000,
          "expect": {
            "ok": true
          }
        },
        {
          "action": "recordCollect",
          "durationMs": 10000
        },
        {
          "action": "canRunCollect",
          "atMs": 36000,
          "expect": {
            "ok": false,
            "reasonCode": "time_budget_reserve"
          }
        }
      ]
    },
    {
      "id": "collect_budget_limit_denies_collect",
      "config": {
        "timeBudgetMinutes": 10,
        "reserveMinutes": 0,
        "maxTotalCollects": 1,
        "minCollectEstimateSeconds": 1
      },
      "timeline": [
        {
          "action": "canRunCollect",
          "atMs": 0,
          "expect": {
            "ok": true
          }
        },
        {
          "action": "recordCollect",
          "durationMs": 1000
        },
        {
          "action": "canRunCollect",
          "atMs": 1000,
          "expect": {
            "ok": false,
            "reasonCode": "collect_budget_limit"
          }
        }
      ]
    }
  ],
