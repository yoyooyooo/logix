{
  "name": "@logixjs/react",
  "version": "1.0.2-beta.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoyooyooo/logix",
    "directory": "packages/logix-react"
  },
  "license": "Apache-2.0",
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./RuntimeProvider": "./src/RuntimeProvider.ts",
    "./Hooks": "./src/Hooks.ts",
    "./FormProjection": "./src/FormProjection.ts",
    "./dev/lifecycle": "./src/dev/lifecycle.ts",
    "./dev/vite": "./src/dev/vite.ts",
    "./dev/vitest": "./src/dev/vitest.ts",
    "./internal/*": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./RuntimeProvider": {
        "types": "./dist/RuntimeProvider.d.ts",
        "import": "./dist/RuntimeProvider.js",
        "require": "./dist/RuntimeProvider.cjs"
      },
      "./Hooks": {
        "types": "./dist/Hooks.d.ts",
        "import": "./dist/Hooks.js",
        "require": "./dist/Hooks.cjs"
      },
      "./FormProjection": {
        "types": "./dist/FormProjection.d.ts",
        "import": "./dist/FormProjection.js",
        "require": "./dist/FormProjection.cjs"
      },
      "./dev/lifecycle": {
        "types": "./dist/dev/lifecycle.d.ts",
        "import": "./dist/dev/lifecycle.js",
        "require": "./dist/dev/lifecycle.cjs"
      },
      "./dev/vite": {
        "types": "./dist/dev/vite.d.ts",
        "import": "./dist/dev/vite.js",
        "require": "./dist/dev/vite.cjs"
      },
      "./dev/vitest": {
        "types": "./dist/dev/vitest.d.ts",
        "import": "./dist/dev/vitest.js",
        "require": "./dist/dev/vitest.cjs"
      },
      "./internal/*": null
    },
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:cache": "vitest run --cache",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@logixjs/core": "workspace:*",
    "@logixjs/form": "workspace:*",
    "effect": "4.0.0-beta.28",
    "use-sync-external-store": "^1.2.0"
  },
  "devDependencies": {
    "@logixjs/test": "workspace:*",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.2",
    "@types/use-sync-external-store": "^1.5.0",
    "@logixjs/perf-evidence": "workspace:*",
    "jsdom": "24.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  }
}
