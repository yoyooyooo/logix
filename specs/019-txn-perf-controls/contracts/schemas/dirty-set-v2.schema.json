{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logix.dev/schemas/019/dirty-set-v2.schema.json",
  "title": "DirtySetV2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "dirtyAll": { "type": "boolean" },
    "reason": {
      "type": "string",
      "enum": ["unknownWrite", "customMutation", "nonTrackablePatch", "fallbackPolicy"]
    },
    "pathIds": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 0
    },
    "pathCount": { "type": "integer", "minimum": 0 },
    "keySize": { "type": "integer", "minimum": 0 },
    "keyHash": { "type": "integer", "minimum": 0 },
    "pathIdsTruncated": { "type": "boolean" }
  },
  "required": ["dirtyAll", "pathIds", "pathCount", "keySize", "keyHash", "pathIdsTruncated"],
  "allOf": [
    {
      "if": { "properties": { "dirtyAll": { "const": false } }, "required": ["dirtyAll"] },
      "then": {
        "properties": {
          "pathIds": { "minItems": 1 },
          "pathCount": { "minimum": 1 },
          "keySize": { "minimum": 1 }
        }
      }
    }
  ]
}
