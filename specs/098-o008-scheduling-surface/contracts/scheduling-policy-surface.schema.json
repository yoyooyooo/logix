{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logix.dev/schemas/098/scheduling-policy-surface.schema.json",
  "title": "SchedulingPolicySurfaceSnapshot",
  "description": "Unified scheduling policy surface snapshot shared by txnQueue, TickScheduler, and concurrency control within one decision window.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "concurrencyLimit": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "const": "unbounded" }
      ]
    },
    "allowUnbounded": { "type": "boolean" },
    "losslessBackpressureCapacity": { "type": "integer", "minimum": 1 },
    "pressureWarningThreshold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backlogCount": { "type": "integer", "minimum": 1 },
        "backlogDurationMs": { "type": "number", "exclusiveMinimum": 0 }
      },
      "required": ["backlogCount", "backlogDurationMs"]
    },
    "warningCooldownMs": { "type": "number", "minimum": 0 },
    "configScope": {
      "type": "string",
      "enum": ["builtin", "runtime_default", "runtime_module", "provider"]
    },
    "resolvedAtTxnSeq": { "type": "integer", "minimum": 0 }
  },
  "required": [
    "concurrencyLimit",
    "allowUnbounded",
    "losslessBackpressureCapacity",
    "pressureWarningThreshold",
    "warningCooldownMs",
    "configScope"
  ]
}
