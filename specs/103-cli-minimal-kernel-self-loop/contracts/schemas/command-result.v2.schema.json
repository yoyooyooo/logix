{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logix/specs/103/command-result.v2.schema.json",
  "title": "CommandResultV2",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "runId",
    "instanceId",
    "txnSeq",
    "opSeq",
    "attemptSeq",
    "command",
    "ok",
    "exitCode",
    "reasonCode",
    "reasonLevel",
    "reasons",
    "artifacts",
    "nextActions",
    "trajectory"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "kind": {
      "const": "CommandResult"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "instanceId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "txnSeq": {
      "type": "integer",
      "minimum": 1
    },
    "opSeq": {
      "type": "integer",
      "minimum": 1
    },
    "attemptSeq": {
      "type": "integer",
      "minimum": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "exitCode": {
      "type": "integer",
      "enum": [0, 1, 2, 3, 4, 5]
    },
    "reasonCode": {
      "type": "string",
      "minLength": 1
    },
    "reasonLevel": {
      "type": "string",
      "enum": ["error", "warn", "info"]
    },
    "reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reasonItem"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactItem"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nextActionItem"
      }
    },
    "trajectory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attemptSeq", "reasonCode"],
        "properties": {
          "attemptSeq": {
            "type": "integer",
            "minimum": 1
          },
          "reasonCode": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "ext": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "reasonItem": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/jsonObject"
        },
        {
          "$ref": "#/$defs/jsonArray"
        }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "artifactItem": {
      "type": "object",
      "required": ["outputKey", "kind", "ok"],
      "properties": {
        "outputKey": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "integer",
          "minimum": 0
        },
        "ok": {
          "type": "boolean"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "inline": {
          "$ref": "#/$defs/jsonValue"
        },
        "truncated": {
          "type": "boolean"
        },
        "budgetBytes": {
          "type": "integer",
          "minimum": 1
        },
        "actualBytes": {
          "type": "integer",
          "minimum": 0
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "error": {
          "$ref": "#/$defs/errorSummary"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["file"],
              "not": {
                "required": ["inline"]
              }
            },
            {
              "required": ["inline"],
              "not": {
                "required": ["file"]
              }
            }
          ]
        },
        {
          "if": {
            "required": ["ok"],
            "properties": {
              "ok": {
                "const": true
              }
            }
          },
          "then": {
            "not": {
              "required": ["error"]
            }
          }
        },
        {
          "if": {
            "required": ["ok"],
            "properties": {
              "ok": {
                "const": false
              }
            }
          },
          "then": {
            "required": ["error"]
          }
        }
      ],
      "additionalProperties": false
    },
    "errorSummary": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "hint": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "nextActionItem": {
      "type": "object",
      "required": ["id", "action"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        },
        "ifReasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
