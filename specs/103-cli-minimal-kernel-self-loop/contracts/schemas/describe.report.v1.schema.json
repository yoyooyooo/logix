{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logix/specs/103/describe.report.v1.schema.json",
  "title": "DescribeReportV1",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "nonGoals",
    "agentGuidance",
    "protocol",
    "commands",
    "runtimeExecutableTruth",
    "migrationEntries",
    "configVisibility"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "CliDescribeReport"
    },
    "nonGoals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "agentGuidance": {
      "$ref": "#/$defs/agentGuidance"
    },
    "protocol": {
      "$ref": "#/$defs/protocol"
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commandContractSummary"
      }
    },
    "runtimeExecutableTruth": {
      "$ref": "#/$defs/runtimeExecutableTruth"
    },
    "migrationEntries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/migrationEntry"
      }
    },
    "configVisibility": {
      "$ref": "#/$defs/configVisibility"
    },
    "ext": {
      "$ref": "#/$defs/extInternalOrchestration"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "commandContractSummary": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "agentGuidance": {
      "type": "object",
      "required": ["source", "verificationChains"],
      "properties": {
        "source": {
          "const": "primitives.capability-model.v1"
        },
        "verificationChains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/verificationChain"
          }
        }
      },
      "additionalProperties": false
    },
    "verificationChain": {
      "type": "object",
      "required": ["id", "purpose", "primitiveChain", "expectedArtifacts", "expectedOutputKeys"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["static-contract", "dynamic-evidence", "change-safety", "closure-ready"]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "primitiveChain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "expectedArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "expectedOutputKeys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "protocol": {
      "type": "object",
      "required": ["commandResultSchemaRef", "reasonCodeCatalogRef", "exitCodes"],
      "properties": {
        "commandResultSchemaRef": {
          "type": "string",
          "minLength": 1
        },
        "reasonCodeCatalogRef": {
          "type": "string",
          "minLength": 1
        },
        "exitCodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/protocolExitCode"
          }
        }
      },
      "additionalProperties": false
    },
    "protocolExitCode": {
      "type": "object",
      "required": ["code", "meaning"],
      "properties": {
        "code": {
          "type": "integer",
          "enum": [0, 1, 2, 3, 4, 5]
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "runtimeExecutableTruth": {
      "type": "object",
      "required": ["source", "executableCommandNames", "migrationCommandNames", "unavailableCommandNames"],
      "properties": {
        "source": {
          "const": "command-registry.availability"
        },
        "executableCommandNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "migrationCommandNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "unavailableCommandNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "migrationEntry": {
      "type": "object",
      "required": ["command", "replacementHint"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "replacementHint": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "configVisibility": {
      "type": "object",
      "required": ["precedence", "argv", "argvWithConfigPrefix", "layers", "effective", "overrideTrail", "discovery"],
      "properties": {
        "precedence": {
          "const": ["defaults", "profile", "env", "argv"]
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "argvWithConfigPrefix": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cliConfigPathArg": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "discoveredPath": {
          "type": "string",
          "minLength": 1
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "effective": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "overrideTrail": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "discovery": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "extInternalOrchestration": {
      "type": "object",
      "required": ["internal"],
      "properties": {
        "internal": {
          "type": "object",
          "required": ["orchestration"],
          "properties": {
            "orchestration": {
              "type": "object",
              "required": ["source", "contractRef", "remediationMapRef", "scenarios"],
              "properties": {
                "source": {
                  "const": "spec-103.scenario-index"
                },
                "contractRef": {
                  "type": "string",
                  "minLength": 1
                },
                "remediationMapRef": {
                  "type": "string",
                  "minLength": 1
                },
                "scenarios": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/orchestrationScenario"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "orchestrationScenario": {
      "type": "object",
      "required": ["id", "recommendedPrimitiveChain"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "recommendedPrimitiveChain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
