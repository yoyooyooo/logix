{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logix/specs/103/extension-manifest.v1.schema.json",
  "title": "ExtensionManifestV1",
  "type": "object",
  "required": ["manifestVersion", "extensionId", "revision", "runtime", "capabilities", "limits"],
  "properties": {
    "manifestVersion": {
      "const": "ext.v1"
    },
    "extensionId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "limits": {
      "$ref": "#/$defs/limits"
    },
    "ext": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "required": ["apiVersion", "entry"],
      "properties": {
        "apiVersion": {
          "type": "string",
          "minLength": 1
        },
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["setup", "onEvent", "snapshot", "restore", "healthcheck", "teardown"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "required": ["hostApis"],
      "properties": {
        "hostApis": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "net": {
          "type": "boolean"
        },
        "fs": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "required": ["timeoutMs"],
      "properties": {
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "maxCpuMs": {
          "type": "integer",
          "minimum": 1
        },
        "maxMemoryMb": {
          "type": "integer",
          "minimum": 16
        },
        "maxQueueSize": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
