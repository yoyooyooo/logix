{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logixjs.dev/schemas/103/scenario-suite.input.v1.schema.json",
  "title": "ScenarioSuiteInput@v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "suiteId",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "ScenarioSuiteInput"
    },
    "suiteId": {
      "type": "string",
      "minLength": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenarioId",
          "playbookPath",
          "requiredArtifacts"
        ],
        "properties": {
          "scenarioId": {
            "type": "string",
            "pattern": "^S[0-9]{2}$"
          },
          "playbookPath": {
            "type": "string",
            "minLength": 1
          },
          "requiredChain": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requiredArtifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
