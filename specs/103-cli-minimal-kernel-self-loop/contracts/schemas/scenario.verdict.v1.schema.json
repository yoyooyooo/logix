{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logixjs.dev/schemas/103/scenario.verdict.v1.schema.json",
  "title": "ScenarioVerdict@v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "scenarioId",
    "runIdPrefix",
    "finalVerdict",
    "finalReasonCode",
    "reasonCodes",
    "decision"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "ScenarioVerdict"
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^S[0-9]{2}$"
    },
    "runIdPrefix": {
      "type": "string",
      "minLength": 1
    },
    "finalVerdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL_HARD",
        "FAIL_SOFT",
        "BLOCKED",
        "INFRA_FLAKY"
      ]
    },
    "finalReasonCode": {
      "type": "string",
      "minLength": 1
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primitiveChain",
        "steps"
      ],
      "properties": {
        "primitiveChain": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "runId",
              "exitCode",
              "reasonCode"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "exitCode": {
                "type": "integer",
                "minimum": 0
              },
              "reasonCode": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
